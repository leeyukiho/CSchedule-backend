NODE_ENV=development
PORT=3000
# 当前未配置云数据库，默认连接本地 PostgreSQL，便于用 Prisma Studio 查看和调整数据。
DATABASE_URL=postgresql://cschedule:cschedule@localhost:5433/cschedule?schema=public&connection_limit=5&pool_timeout=10
CORS_ORIGIN=http://localhost:10086
ADMIN_API_KEY=change-me-to-a-secure-random-string
CREDENTIAL_VAULT_KEY=change-me-to-a-32-byte-random-secret
CREDENTIAL_VAULT_KEY_VERSION=v1
REQUEST_BODY_LIMIT=256kb
RAW_DATA_BODY_LIMIT=2mb
SYNC_GLOBAL_CONCURRENCY=2
SYNC_SCHOOL_CONCURRENCY=1
SYNC_STALE_JOB_MS=1200000
SYNC_ACCOUNT_COOLDOWN_MS=600000
CLOUDBASE_ENV_ID=unilinkcore-d5g3fcm1ja9274245
CSCHEDULE_WORKER_SECRET=
# Required only when the backend calls CloudBase functions outside a CloudBase runtime.
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=
# Required when using temporary credentials from `tcb secrets get`.
TENCENTCLOUD_SESSIONTOKEN=
TENCENTCLOUD_CREDENTIAL_EXPIRES_AT=
AUTO_SYNC_ENABLED=false
AUTO_SYNC_SCAN_INTERVAL_MS=600000
AUTO_SYNC_MIN_INTERVAL_MS=21600000
AUTO_SYNC_BATCH_SIZE=20
AUTO_SYNC_TARGETS=course

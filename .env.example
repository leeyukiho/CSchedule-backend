# 运行环境标识；当前后端业务代码不直接分支使用，生产建议改为 production。
NODE_ENV=development

# 后端监听端口；Nginx 会反向代理到这个端口。
PORT=3000

# PostgreSQL 连接地址；Prisma 读这个变量连接数据库。
DATABASE_URL=postgresql://cschedule:cschedule@localhost:5433/cschedule?schema=public&connection_limit=5&pool_timeout=10

# 允许跨域访问后端的来源，多个来源用英文逗号分隔。
CORS_ORIGIN=http://localhost:10086

# 管理接口密钥；访问 Admin 接口时需要用它做鉴权，生产必须改成随机长字符串。
ADMIN_API_KEY=change-me-to-a-secure-random-string

# 学号密码保存到数据库前的加密密钥；启用保存凭据/自动同步时必须配置，生产后不要随意更换。
CREDENTIAL_VAULT_KEY=change-me-to-a-32-byte-random-secret

# 凭据加密密钥版本号；用于标记密文使用的密钥版本，轮换密钥时区分新旧版本。
CREDENTIAL_VAULT_KEY_VERSION=v1

# 普通 JSON 请求体大小限制。
REQUEST_BODY_LIMIT=256kb

# 原始课表/成绩等大 payload 接口的请求体大小限制。
RAW_DATA_BODY_LIMIT=2mb

# 全局同步任务并发数；限制同时运行的同步任务总量。
SYNC_GLOBAL_CONCURRENCY=2

# 单个学校同步任务并发数；避免同一学校接口被并发打爆。
SYNC_SCHOOL_CONCURRENCY=1

# 同步任务超时时间，单位毫秒；超过后会被视为卡死任务并标记失败。
SYNC_STALE_JOB_MS=1200000

# 同一账号手动同步冷却时间，单位毫秒；防止用户频繁触发同步。
SYNC_ACCOUNT_COOLDOWN_MS=600000

# CloudBase 环境 ID；仅在后端通过 CloudBase SDK 调用函数名时需要，走 HTTP 云函数 URL 时通常不需要。
CLOUDBASE_ENV_ID=unilinkcore-d5g3fcm1ja9274245

# 后端请求云函数时附带的内部密钥；云函数若校验 x-cschedule-worker-secret 才需要填写。
CSCHEDULE_WORKER_SECRET=

# 腾讯云永久密钥 ID；仅当后端在服务器上通过 CloudBase SDK 调用函数名时需要，走 HTTP URL 不需要。
TENCENTCLOUD_SECRETID=

# 腾讯云永久密钥 Key；仅当填写 TENCENTCLOUD_SECRETID 并通过 CloudBase SDK 调用函数名时需要。
TENCENTCLOUD_SECRETKEY=

# 腾讯云临时凭证 Token；只在不用永久密钥、改用临时凭证调用 CloudBase SDK 时需要。
TENCENTCLOUD_SESSIONTOKEN=

# 腾讯云临时凭证过期时间；配合 TENCENTCLOUD_SESSIONTOKEN 使用，过期后后端会拒绝继续调用。
TENCENTCLOUD_CREDENTIAL_EXPIRES_AT=

# 是否启用后台自动同步；false 时只响应用户手动同步。
AUTO_SYNC_ENABLED=false

# 自动同步扫描间隔，单位毫秒；启用 AUTO_SYNC_ENABLED 后按这个频率扫描账号。
AUTO_SYNC_SCAN_INTERVAL_MS=600000

# 同一账号自动同步最小间隔，单位毫秒；避免自动同步过于频繁。
AUTO_SYNC_MIN_INTERVAL_MS=21600000

# 每轮自动同步最多处理的账号数。
AUTO_SYNC_BATCH_SIZE=20

# 自动同步的数据目标，多个用英文逗号分隔，可选 course、score、exam、profile。
AUTO_SYNC_TARGETS=course
